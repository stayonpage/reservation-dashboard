# 이 파일을 .env.local 로 복사하고 값을 채운 뒤 서버를 재시작하세요.
# .env.local은 .gitignore에 포함되어 커밋되지 않습니다.

# --- 클라이언트+서버 공용 (Supabase 대시보드 > Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon-key...

# --- 서버 전용: 파싱 워커(네이버 메일/스테이폴리오 문자 IMAP, 아임웹 웹훅)가 사용 ---
# secret key(구 service_role)는 RLS를 우회하므로 절대 클라이언트로 노출하지 말 것(lib/ingest.ts에서만 사용).
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# --- 네이버 메일 IMAP (예약 알림 수신용 계정) ---
# 2025-06 정책 변경으로 일반 로그인 비밀번호로는 IMAP 접속 불가.
# 네이버 로그인 > 보안설정 > 2단계 인증 관리 > 애플리케이션 비밀번호 관리 에서 발급.
NAVER_MAIL_USER=example@naver.com
NAVER_MAIL_APP_PASSWORD=발급받은-앱-비밀번호

# --- 지메일 IMAP (스테이폴리오·아임웹 이메일 알림 수신용 계정) ---
# 구글 계정 > 보안 > 2단계 인증 > 앱 비밀번호 에서 발급.
GMAIL_MAIL_USER=example@gmail.com
GMAIL_MAIL_APP_PASSWORD=발급받은-앱-비밀번호

# --- 폴링 엔드포인트 보호용 공유키 (아무 임의의 긴 문자열, Vercel Cron 설정에도 동일하게 등록) ---
CRON_SECRET=랜덤한-긴-문자열

# --- 셋업 순서 ---
# 1) Supabase 프로젝트 생성 후 위 SUPABASE 값 채우기
# 2) supabase/migrations/*.sql 을 0001부터 번호 순서대로 SQL 에디터에서 실행
# 3) Authentication > Users 에서 직원 4명 계정을 이메일/비밀번호로 생성(자체가입 없음)
# 4) 네이버·지메일 앱 비밀번호 발급 후 NAVER_MAIL_*/GMAIL_MAIL_* 채우기, CRON_SECRET은 임의 문자열로 채우기
# 5) npm run dev 재시작 후 /login 에서 로그인
# 6) 수동 폴링 테스트: curl -H "Authorization: Bearer $CRON_SECRET" http://localhost:3001/api/cron/poll-naver
